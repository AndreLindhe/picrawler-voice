# Copy to .env and fill in values.  Never commit .env to git.

# Ollama server (LAN or localhost)
OLLAMA_HOST=http://192.168.50.100:11434
OLLAMA_MODEL=llama3.2:3b

# Whisper model size for STT (runs on CPU; tiny is fast enough for short commands)
# Options: tiny, base, small, medium
WHISPER_MODEL=tiny

# Piper TTS — full path to the .onnx model file.
# Leave empty to fall back to espeak-ng (installed by default on Pi OS).
# Download models: https://github.com/rhasspy/piper/releases
PIPER_MODEL=/home/penguin/models/en_US-lessac-medium.onnx

# Wake word detection sensitivity (0.0–1.0; lower = more sensitive)
WAKE_WORD_THRESHOLD=0.5
